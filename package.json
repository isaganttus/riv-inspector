{
  "name": "riv-inspector",
  "version": "0.2.0",
  "description": "Extract metadata from .riv files as Markdown with YAML frontmatter",
  "author": "Isa Ganttus",
  "license": "MIT",
  "keywords": [
    "rive",
    "riv",
    "inspector",
    "metadata",
    "cli",
    "animation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/isaganttus/riv-inspector.git"
  },
  "bugs": {
    "url": "https://github.com/isaganttus/riv-inspector/issues"
  },
  "homepage": "https://github.com/isaganttus/riv-inspector#readme",
  "type": "module",
  "bin": {
    "riv-inspector": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "biome check .",
    "check:write": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "node --import tsx/esm --test test/cli.test.ts test/inspector.test.ts",
    "typecheck": "tsc --noEmit",
    "pack:dry-run": "npm --cache .npm-cache pack --dry-run",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=22.6.0"
  },
  "dependencies": {
    "@rive-app/canvas-advanced": "^2.37.3",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.6.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2"
  }
}
